# Backend API base URL for production deployments.
# Replace with your actual deployed backend URL (no trailing slash).
# Examples:
#   Render:   https://venuesync-api.onrender.com
#   Railway:  https://venuesync-api.up.railway.app
#   Fly.io:   https://venuesync-api.fly.dev
VITE_API_BASE_URL=https://your-backend-url.com

# Public OIDC/Keycloak settings used by the browser.
# The authority must match the backend KEYCLOAK_ISSUER_URI.
VITE_OIDC_AUTHORITY=https://keycloak-server-3dsx.onrender.com/realms/event-ticket-platform
VITE_OIDC_CLIENT_ID=event-ticket-platform-app
