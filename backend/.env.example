# ---------- Runtime profile ----------
SPRING_PROFILES_ACTIVE=prod
APP_TIMEZONE=Asia/Kolkata

# ---------- Backend host port ----------
# Local option: 8080
# EC2/API Gateway option: 80
BACKEND_HOST_PORT=80

# ---------- Database ----------
DATABASE_URL=jdbc:postgresql://db:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=changemeinprod!
DB_HOST_PORT=5433

# ---------- Keycloak ----------
KEYCLOAK_HOST_PORT=9090
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Public URL where browser and OIDC clients reach Keycloak.
# Local example: http://localhost:9090
# Tunnel/prod example: https://your-tunnel.trycloudflare.com
KEYCLOAK_PUBLIC_BASE_URL=http://localhost:9090
# Keycloak hostname/proxy settings so OIDC metadata advertises the same public URL.
KC_PROXY_HEADERS=xforwarded
KC_HTTP_ENABLED=true
KC_HOSTNAME_STRICT=true
# Backend token issuer validation URL. Keep this aligned with KEYCLOAK_PUBLIC_BASE_URL.
KEYCLOAK_ISSUER_URI=http://localhost:9090/realms/event-ticket-platform

# ---------- Adminer ----------
ADMINER_HOST_PORT=8888

# ---------- CORS ----------
# Comma-separated. Add your current Cloudflare preview URL if testing preview deployments.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://venuesync.pages.dev,https://aeea1436.venuesync.pages.dev
